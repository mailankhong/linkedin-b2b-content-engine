# Universal Content Machine — Environment Variables
# Copy this file to .env and fill in your own values
# Never commit your .env file to GitHub
#
# ── RESEARCH & SCRAPING ──
# APIFY_API_KEY=your-apify-key-here
#
# ── VISUAL GENERATION ──
# GOOGLE_API_KEY=your-google-api-key-here
#
# ── SOCIAL LISTENING ──
# X_COOKIES=your-x-cookies-here
#
# ── CONTENT ANALYTICS (optional) ──
# SHIELD_API_KEY=your-shield-key-here
# TAPLIO_API_KEY=your-taplio-key-here
# SCRIPE_API_KEY=your-scripe-key-here
#
# ── ADD NEW INTEGRATIONS BELOW ──
# Follow the same format: TOOL_NAME_API_KEY=your-key-here
